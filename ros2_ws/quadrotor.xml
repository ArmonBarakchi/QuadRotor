<mujoco model="quadrotor">

  <compiler angle="radian" autolimits="true"/>

  <!--
    Crazyflie-class micro quadrotor
    Total mass  : ~34g
    Arm length  : 46mm (center to rotor)
    Max thrust  : 0.15 N per rotor  (0.6 N total = ~1.8x hover thrust)
  -->
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <default>
    <joint damping="0.0005"/>
    <geom rgba="0.3 0.3 0.3 1"/>
  </default>

  <asset>
    <material name="body_mat"  rgba="0.2 0.2 0.8 1"/>
    <material name="rotor_mat" rgba="0.8 0.2 0.2 1"/>
    <material name="arm_mat"   rgba="0.15 0.15 0.15 1"/>
  </asset>

  <worldbody>

    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="ground" type="plane" size="5 5 0.1" rgba="0.6 0.6 0.6 1"/>

    <body name="quadrotor" pos="0 0 0.1">

      <freejoint name="root"/>

      <!-- Central hub: 27g, radius 30mm -->
      <geom name="hub" type="cylinder" size="0.03 0.008"
            material="body_mat" mass="0.027"/>

      <!-- IMU site at CoM -->
      <site name="imu" pos="0 0 0" size="0.005"/>

      <!-- Arms: 2g each, 46mm from center (X config) -->
      <geom name="arm1" type="capsule"
            fromto="0 0 0  0.0325 0.0325 0"
            size="0.004" material="arm_mat" mass="0.002"/>
      <geom name="arm2" type="capsule"
            fromto="0 0 0  0.0325 -0.0325 0"
            size="0.004" material="arm_mat" mass="0.002"/>
      <geom name="arm3" type="capsule"
            fromto="0 0 0  -0.0325 -0.0325 0"
            size="0.004" material="arm_mat" mass="0.002"/>
      <geom name="arm4" type="capsule"
            fromto="0 0 0  -0.0325 0.0325 0"
            size="0.004" material="arm_mat" mass="0.002"/>

      <!-- Rotor discs: 1g each -->
      <geom name="rotor1" type="cylinder" size="0.023 0.002"
            pos=" 0.0325  0.0325 0.006" material="rotor_mat" mass="0.001"/>
      <geom name="rotor2" type="cylinder" size="0.023 0.002"
            pos=" 0.0325 -0.0325 0.006" material="rotor_mat" mass="0.001"/>
      <geom name="rotor3" type="cylinder" size="0.023 0.002"
            pos="-0.0325 -0.0325 0.006" material="rotor_mat" mass="0.001"/>
      <geom name="rotor4" type="cylinder" size="0.023 0.002"
            pos="-0.0325  0.0325 0.006" material="rotor_mat" mass="0.001"/>

      <!-- Thrust sites -->
      <site name="rotor1_site" pos=" 0.0325  0.0325 0.006" size="0.003"/>
      <site name="rotor2_site" pos=" 0.0325 -0.0325 0.006" size="0.003"/>
      <site name="rotor3_site" pos="-0.0325 -0.0325 0.006" size="0.003"/>
      <site name="rotor4_site" pos="-0.0325  0.0325 0.006" size="0.003"/>

    </body>
  </worldbody>

  <!-- Max thrust 0.15 N per rotor (total 0.6 N vs hover need of ~0.33 N) -->
  <actuator>
    <general name="rotor1" site="rotor1_site"
             gear="0 0 1 0 0 0" ctrllimited="true" ctrlrange="0 0.15"/>
    <general name="rotor2" site="rotor2_site"
             gear="0 0 1 0 0 0" ctrllimited="true" ctrlrange="0 0.15"/>
    <general name="rotor3" site="rotor3_site"
             gear="0 0 1 0 0 0" ctrllimited="true" ctrlrange="0 0.15"/>
    <general name="rotor4" site="rotor4_site"
             gear="0 0 1 0 0 0" ctrllimited="true" ctrlrange="0 0.15"/>
  </actuator>

  <sensor>
    <accelerometer name="accel" site="imu"/>
    <gyro          name="gyro"  site="imu"/>
  </sensor>

</mujoco>